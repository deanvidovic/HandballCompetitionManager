@model IReadOnlyCollection<MatchAttachment>

@{
    var canManageMatchReport = ViewBag.CanManageMatchReport == true;
}

@if (Model.Count == 0)
{
    <p class="match-report-empty">No match reports uploaded yet.</p>
}
else
{
    <div class="match-report-list">
        @foreach (var attachment in Model)
        {
            <article class="match-report-current">
                <div>
                    <span class="match-report-label">@attachment.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                    <a href="@attachment.FilePath" target="_blank" rel="noopener" class="match-report-link">
                        @attachment.FileName
                    </a>
                    <span class="match-report-meta">@((attachment.FileSize / 1024.0).ToString("0.#")) KB</span>
                </div>
                @if (canManageMatchReport)
                {
                    <button type="button"
                            class="match-report-remove-file"
                            aria-label="Remove @attachment.FileName"
                            data-delete-attachment-url="@Url.Action("DeleteAttachment", "Matches", new { id = attachment.Id })">x</button>
                }
            </article>
        }
    </div>
}
