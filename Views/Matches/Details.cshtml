@model Match

@{
    ViewData["Title"] = $"Match Details - {ViewBag.HomeTeamName} vs {ViewBag.AwayTeamName}";
    var homeTeam = ViewBag.TeamRepository?.GetById(Model.HomeTeamId);
    var awayTeam = ViewBag.TeamRepository?.GetById(Model.AwayTeamId);
    var venueName = !string.IsNullOrWhiteSpace(Model.MaintenanceHall)
        ? Model.MaintenanceHall
        : homeTeam?.HomeArena ?? "Venue not assigned";
}

<link rel="stylesheet" href="~/css/matches.css" asp-append-version="true" />

<div class="matches-details-container match-details-modern">
    <div class="back-navigation">
        <a href="@Url.Action("Index", "Matches")" class="back-link">
            <span class="back-arrow">&larr;</span>
            Back to Matches
        </a>
    </div>

    <div class="breadcrumb-section">
        <nav class="breadcrumb-nav" aria-label="Breadcrumb">
            <a href="/" class="breadcrumb-link">Home</a>
            <span class="breadcrumb-separator">/</span>
            <a href="@Url.Action("Index", "Matches")" class="breadcrumb-link">Matches</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Match Details</span>
        </nav>
    </div>

    <header class="match-details-hero">
        <div class="match-details-heading">
            <p class="match-details-eyebrow">Match details</p>
            <h1 class="matches-details-title">
                <span>@ViewBag.HomeTeamName</span>
                <span class="vs-separator">vs</span>
                <span>@ViewBag.AwayTeamName</span>
            </h1>
            <div class="match-details-meta-line">
                <span>@Model.Kickoff.ToString("dd MMM yyyy")</span>
                <span>@Model.Kickoff.ToString("HH:mm")</span>
                <span>@venueName</span>
            </div>
        </div>
        <div class="match-details-actions">
            <span class="status-badge-large status-@Model.Status.ToString().ToLower()">@Model.Status</span>
            <a href="@Url.Action("Index", "Matches")" class="details-back-link">Back to Matches</a>
        </div>
    </header>

    <main class="matches-details-content">
        <section class="match-score-section match-score-modern" aria-label="Score summary">
            <div class="score-team">
                <span class="score-team-label">Home</span>
                <span class="score-team-name">@ViewBag.HomeTeamName</span>
            </div>
            <div class="score-card">
                <span class="score-number">@Model.HomeScore</span>
                <span class="score-divider">-</span>
                <span class="score-number">@Model.AwayScore</span>
            </div>
            <div class="score-team score-team-away">
                <span class="score-team-label">Away</span>
                <span class="score-team-name">@ViewBag.AwayTeamName</span>
            </div>
        </section>

        <section class="match-overview-section match-details-panel" aria-labelledby="matchOverviewTitle">
            <div class="details-section-header">
                <h2 id="matchOverviewTitle" class="section-title">Overview</h2>
            </div>
            <div class="overview-grid">
                @if (Model.RoundNumber > 0)
                {
                    <article class="overview-card">
                        <span class="overview-label">Round</span>
                        <span class="overview-value">Round @Model.RoundNumber</span>
                    </article>
                }
                <article class="overview-card">
                    <span class="overview-label">Date</span>
                    <span class="overview-value">@Model.Kickoff.ToString("MMM dd, yyyy")</span>
                </article>
                <article class="overview-card">
                    <span class="overview-label">Time</span>
                    <span class="overview-value">@Model.Kickoff.ToString("HH:mm")</span>
                </article>
                <article class="overview-card">
                    <span class="overview-label">Venue</span>
                    <span class="overview-value">@venueName</span>
                </article>
                <article class="overview-card">
                    <span class="overview-label">Competition</span>
                    <a href="@Url.Action("Details", "Competitions", new { id = Model.CompetitionId })" class="overview-value competition-link">
                        @ViewBag.CompetitionName
                    </a>
                </article>
            </div>
        </section>

        <section class="match-teams-section match-details-panel" aria-labelledby="teamInfoTitle">
            <div class="details-section-header">
                <h2 id="teamInfoTitle" class="section-title">Teams</h2>
            </div>
            <div class="teams-comparison-grid">
                <article class="team-comparison-card">
                    <div class="team-comparison-header">
                        <span class="team-side-label">Home Team</span>
                        <h3 class="team-comparison-name">@ViewBag.HomeTeamName</h3>
                    </div>
                    <div class="team-comparison-content">
                        @if (homeTeam != null)
                        {
                            <div class="team-info-item">
                                <span class="info-label">Coach</span>
                                <span class="info-value">@homeTeam.CoachName</span>
                            </div>
                            <div class="team-info-item">
                                <span class="info-label">City</span>
                                <span class="info-value">@homeTeam.HomeCity</span>
                            </div>
                            <div class="team-info-item">
                                <span class="info-label">Players</span>
                                <span class="info-value">@(homeTeam.Players?.Count ?? 0)</span>
                            </div>
                            <a href="@Url.Action("Details", "Teams", new { id = homeTeam.Id })" class="team-view-link">View Team</a>
                        }
                        else
                        {
                            <p class="info-placeholder">Team information is not available.</p>
                        }
                    </div>
                </article>

                <article class="team-comparison-card">
                    <div class="team-comparison-header">
                        <span class="team-side-label">Away Team</span>
                        <h3 class="team-comparison-name">@ViewBag.AwayTeamName</h3>
                    </div>
                    <div class="team-comparison-content">
                        @if (awayTeam != null)
                        {
                            <div class="team-info-item">
                                <span class="info-label">Coach</span>
                                <span class="info-value">@awayTeam.CoachName</span>
                            </div>
                            <div class="team-info-item">
                                <span class="info-label">City</span>
                                <span class="info-value">@awayTeam.HomeCity</span>
                            </div>
                            <div class="team-info-item">
                                <span class="info-label">Players</span>
                                <span class="info-value">@(awayTeam.Players?.Count ?? 0)</span>
                            </div>
                            <a href="@Url.Action("Details", "Teams", new { id = awayTeam.Id })" class="team-view-link">View Team</a>
                        }
                        else
                        {
                            <p class="info-placeholder">Team information is not available.</p>
                        }
                    </div>
                </article>
            </div>
        </section>
    </main>
</div>
