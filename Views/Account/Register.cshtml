@{
    ViewData["Title"] = "Sign Up";
}

@section Styles {
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
}

<div class="register-page">
    <div class="page-shell">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">&rarr;</span>
            <span aria-current="page">Sign Up</span>
        </nav>

        <header class="register-header">
            <h1>Create your account</h1>
            <p>Join Handball Competition Manager and start participating in handball tournaments.</p>
        </header>

        <section class="register-card" aria-label="Create an account">
            <form class="register-form">
                <div class="name-fields">
                    <div class="form-field">
                        <label for="first-name">First Name</label>
                        <input id="first-name" name="first-name" type="text" autocomplete="given-name" />
                    </div>
                    <div class="form-field">
                        <label for="last-name">Last Name</label>
                        <input id="last-name" name="last-name" type="text" autocomplete="family-name" />
                    </div>
                </div>

                <div class="form-field">
                    <label for="email">Email Address</label>
                    <input id="email" name="email" type="email" autocomplete="email" />
                </div>

                <div class="form-field">
                    <label for="password">Password</label>
                    <input id="password" name="password" type="password" autocomplete="new-password" />
                </div>

                <div class="form-field">
                    <label for="confirm-password">Confirm Password</label>
                    <input id="confirm-password" name="confirm-password" type="password" autocomplete="new-password" />
                </div>

                <button class="button button--primary create-account-button" type="submit" disabled>Create Account</button>
            </form>

            <p class="sign-in-prompt">Already have an account? <a href="/Account/Login">Sign In</a></p>

            <div class="oauth-divider"><span>or</span></div>

            <button class="button google-button" type="button">
                <span class="google-icon" aria-hidden="true">G</span>
                Continue with Google
            </button>

            <p class="terms-copy">By creating an account, you agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.</p>
        </section>
    </div>
</div>

<footer class="site-footer">
    <div class="page-shell site-footer__inner">
        <span>Handball Competition Manager</span>
        <a href="/Tournaments">Tournaments</a>
    </div>
</footer>
