@model List<Player>

@{
    ViewData["Title"] = "Players";
    ViewData["SearchTitle"] = "Search players";
    ViewData["SearchLabel"] = "Search";
    ViewData["SearchPlaceholder"] = "Search by player name, team, position, or jersey number";
    ViewData["SearchHint"] = "Use keywords to narrow the player list.";
    ViewData["SearchSectionLabel"] = "Player search";
    var canManagePlayers = User.IsInRole("Admin") || User.IsInRole("Coach");
    var isAdmin = User.IsInRole("Admin");
}

<link rel="stylesheet" href="~/css/players.css" asp-append-version="true" />

<div class="players-container">
    <div class="breadcrumb-section">
        <nav class="breadcrumb-nav">
            <a href="/" class="breadcrumb-link">Home</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-current">Players</span>
        </nav>
    </div>

    <div class="players-header">
        <div class="header-content">
            <h1 class="players-title">Handball Players</h1>
            <p class="players-subtitle">View all competition players and their statistics</p>
        </div>
        @if (canManagePlayers)
        {
            <button type="button" class="btn btn-create" data-player-modal-open aria-haspopup="dialog" aria-controls="createPlayerModal">
                <span class="btn-icon" aria-hidden="true">+</span>
                Create Player
            </button>
        }
    </div>

    <section class="competition-search" aria-label="@ViewData["SearchSectionLabel"]">
        <form class="competition-search-form" asp-action="Index" asp-controller="Players" method="get" data-search-form="players">
            <div class="search-header">
                <div>
                    <h2 class="search-title">@ViewData["SearchTitle"]</h2>
                    <p class="search-subtitle">@ViewData["SearchHint"]</p>
                </div>
            </div>
            <div class="search-input-group">
                <label class="search-label" for="playerSearch">@ViewData["SearchLabel"]</label>
                <div class="search-input-wrapper">
                    <span class="search-icon" aria-hidden="true">
                        <i class="fas fa-magnifying-glass"></i>
                    </span>
                    <input type="search" id="playerSearch" name="query" value="@ViewData["Query"]" class="search-input" placeholder="@ViewData["SearchPlaceholder"]" autocomplete="off" data-autocomplete-url="@Url.Action("Autocomplete", "Players")" />
                </div>
            </div>
        </form>
    </section>

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">👥</div>
            <h2 class="empty-state-title">No Players Available</h2>
            <p class="empty-state-message">There are currently no players in the system.</p>
        </div>
    }
    else
    {
        <div class="players-list">
            @foreach (var player in Model)
            {
                <div class="player-list-item">
                    <a href="@Url.Action("Details", "Players", new { id = player.Id })" class="player-main-link">
                        <div class="player-info">
                            <div class="player-jersey-badge">@player.JerseyNumber</div>
                            <div class="player-name-section">
                                <h2 class="player-name">@player.FullName</h2>
                                <p class="player-team">@player.Team?.Name</p>
                            </div>
                        </div>
                        <div class="player-details">
                            <div class="player-detail-item">
                                <span class="player-detail-label">Goals</span>
                                <span class="player-detail-value">@player.GoalsScored</span>
                            </div>
                            <div class="player-detail-item">
                                <span class="player-detail-label">Assists</span>
                                <span class="player-detail-value">@player.Assists</span>
                            </div>
                            <div class="player-detail-item">
                                <span class="player-detail-label">Age</span>
                                <span class="player-detail-value">@(DateTime.Now.Year - player.BirthDate.Year)</span>
                            </div>
                        </div>
                        <div class="player-position">
                            <span class="position-badge">@player.Position</span>
                        </div>
                    </a>
                    @if (canManagePlayers)
                    {
                        <div class="player-actions">
                            <button type="button" class="btn btn-edit" data-edit-player data-edit-url="@Url.Action("Edit", "Players")" data-id="@player.Id" data-first-name="@player.FirstName" data-last-name="@player.LastName" data-birth-date="@player.BirthDate.ToString("yyyy-MM-dd")" data-jersey-number="@player.JerseyNumber" data-position="@player.Position" data-team-id="@player.TeamId" data-team-name="@player.Team?.Name" data-goals-scored="@player.GoalsScored" data-assists="@player.Assists">Edit</button>
                            @if (isAdmin)
                            {
                                <form asp-action="DeleteConfirmed" asp-controller="Players" method="post" class="delete-form" data-delete-form data-delete-name="@player.FullName">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@player.Id" />
                                    <button type="submit" class="btn btn-delete">Delete</button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<div class="player-modal" id="createPlayerModal" role="dialog" aria-modal="true" aria-labelledby="createPlayerTitle" hidden data-player-modal>
    <div class="player-modal-backdrop" data-player-modal-close></div>
    <section class="player-modal-panel" aria-describedby="createPlayerDescription">
        <header class="player-modal-header">
            <div>
                <p class="player-modal-eyebrow">New player</p>
                <h2 class="player-modal-title" id="createPlayerTitle">Create Player</h2>
                <p class="player-modal-description" id="createPlayerDescription">Add player identity, team assignment, position, and starting statistics.</p>
            </div>
            <button type="button" class="player-modal-close" data-player-modal-close aria-label="Close create player form">
                <i class="fas fa-xmark" aria-hidden="true"></i>
            </button>
        </header>

        <form class="player-create-form" asp-action="Create" asp-controller="Players" method="post" data-player-create-form>
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="0" data-edit-id />
            <div class="player-form-grid">
                <div class="player-form-field" data-player-field="FirstName">
                    <label class="player-form-label" for="playerFirstName">First name</label>
                    <input class="player-form-input" id="playerFirstName" name="FirstName" type="text" autocomplete="given-name" placeholder="Domagoj" required minlength="2" maxlength="80" data-player-validate-field="FirstName" aria-describedby="playerFirstNameValidation" />
                    <span class="player-validation-message" id="playerFirstNameValidation" data-player-validation-message-for="FirstName" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="LastName">
                    <label class="player-form-label" for="playerLastName">Last name</label>
                    <input class="player-form-input" id="playerLastName" name="LastName" type="text" autocomplete="family-name" placeholder="Duvnjak" required minlength="2" maxlength="80" data-player-validate-field="LastName" aria-describedby="playerLastNameValidation" />
                    <span class="player-validation-message" id="playerLastNameValidation" data-player-validation-message-for="LastName" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="BirthDate">
                    <label class="player-form-label" for="playerBirthDate">Birth date</label>
                    @await Html.PartialAsync("_DateTimePicker", new HandballCompetitionManager.ViewModels.DateTimePickerViewModel
                    {
                        Name = "BirthDate",
                        Id = "playerBirthDate",
                        Label = "Birth date",
                        Placeholder = "Select birth date",
                        DescribedBy = "playerBirthDateValidation",
                        Required = true,
                        ValidationField = "BirthDate"
                    })
                    <span class="player-validation-message" id="playerBirthDateValidation" data-player-validation-message-for="BirthDate" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="JerseyNumber">
                    <label class="player-form-label" for="playerJerseyNumber">Jersey number</label>
                    <input class="player-form-input" id="playerJerseyNumber" name="JerseyNumber" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="10" required min="1" max="99" data-player-validate-field="JerseyNumber" aria-describedby="playerJerseyNumberValidation" />
                    <span class="player-validation-message" id="playerJerseyNumberValidation" data-player-validation-message-for="JerseyNumber" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="Position">
                    <label class="player-form-label" for="playerPosition">Position</label>
                    <select class="player-form-input" id="playerPosition" name="Position" required data-player-validate-field="Position" aria-describedby="playerPositionValidation">
                        <option value="">Select position</option>
                        @foreach (var position in Enum.GetValues<PlayerPosition>())
                        {
                            <option value="@position">@position</option>
                        }
                    </select>
                    <span class="player-validation-message" id="playerPositionValidation" data-player-validation-message-for="Position" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="TeamId">
                    <label class="player-form-label" for="playerTeam">Team</label>
                    <div class="player-team-autocomplete" data-player-team-autocomplete>
                        <input class="player-form-input" id="playerTeam" type="text" autocomplete="off" placeholder="Start typing a team name" data-player-team-input data-player-team-autocomplete-url="@Url.Action("TeamAutocomplete", "Players")" data-player-validate-field="TeamId" aria-autocomplete="list" aria-expanded="false" aria-controls="playerTeamAutocompleteResults" aria-describedby="playerTeamValidation" required maxlength="120" />
                        <input type="hidden" id="playerTeamId" name="TeamId" data-player-team-id />
                        <button type="button" class="player-team-clear" data-player-team-clear aria-label="Remove selected team" hidden>
                            <i class="fas fa-xmark" aria-hidden="true"></i>
                        </button>
                        <div class="player-team-results" id="playerTeamAutocompleteResults" role="listbox" hidden data-player-team-results></div>
                    </div>
                    <span class="player-validation-message" id="playerTeamValidation" data-player-validation-message-for="TeamId" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="GoalsScored">
                    <label class="player-form-label" for="playerGoalsScored">Goals scored</label>
                    <input class="player-form-input" id="playerGoalsScored" name="GoalsScored" type="text" inputmode="numeric" pattern="[0-9]*" value="0" required data-player-validate-field="GoalsScored" aria-describedby="playerGoalsScoredValidation" />
                    <span class="player-validation-message" id="playerGoalsScoredValidation" data-player-validation-message-for="GoalsScored" aria-live="polite"></span>
                </div>

                <div class="player-form-field" data-player-field="Assists">
                    <label class="player-form-label" for="playerAssists">Assists</label>
                    <input class="player-form-input" id="playerAssists" name="Assists" type="text" inputmode="numeric" pattern="[0-9]*" value="0" required data-player-validate-field="Assists" aria-describedby="playerAssistsValidation" />
                    <span class="player-validation-message" id="playerAssistsValidation" data-player-validation-message-for="Assists" aria-live="polite"></span>
                </div>
            </div>

            <div class="player-form-status" role="status" data-player-form-status hidden></div>

            <footer class="player-modal-actions">
                <button type="button" class="btn btn-secondary player-modal-secondary" data-player-modal-close>Cancel</button>
                <button type="submit" class="btn btn-create player-modal-submit">Save Player</button>
            </footer>
        </form>
    </section>
</div>

@section Scripts {
    <script src="~/js/players.js" asp-append-version="true"></script>
}
